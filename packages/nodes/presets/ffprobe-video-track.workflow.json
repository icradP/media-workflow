{
  "version": 1,
  "name": "FFprobe Video Track Validation",
  "description": "Select the first video track, take its first key frame, and inspect exact packet bytes.",
  "nodes": [
    { "id": "file", "type": "file_loader", "position": [40, 180] },
    { "id": "analyze", "type": "auto_analyze", "position": [300, 180] },
    {
      "id": "track",
      "type": "track_select",
      "position": [580, 80],
      "params": { "kind": "video", "index": 0 }
    },
    { "id": "detail", "type": "track_detail", "position": [900, 20] },
    {
      "id": "select-frames",
      "type": "media_select",
      "position": [880, 260],
      "params": {
        "startIndex": 0,
        "endIndex": -1,
        "startTimeSeconds": 0,
        "endTimeSeconds": -1,
        "frameType": "key",
        "limit": 1
      }
    },
    { "id": "frame-table", "type": "sample_table", "position": [1220, 190] },
    {
      "id": "frame-hex",
      "type": "hex_view",
      "position": [1220, 430],
      "params": { "offset": 0, "length": 512 }
    }
  ],
  "edges": [
    {
      "id": "file-analyze",
      "sourceNodeId": "file",
      "sourceOutput": "source",
      "targetNodeId": "analyze",
      "targetInput": "source"
    },
    {
      "id": "analyze-track",
      "sourceNodeId": "analyze",
      "sourceOutput": "asset",
      "targetNodeId": "track",
      "targetInput": "asset"
    },
    {
      "id": "track-detail",
      "sourceNodeId": "track",
      "sourceOutput": "selectedTrack",
      "targetNodeId": "detail",
      "targetInput": "selectedTrack"
    },
    {
      "id": "track-select-frames",
      "sourceNodeId": "track",
      "sourceOutput": "selectedTrack",
      "targetNodeId": "select-frames",
      "targetInput": "source"
    },
    {
      "id": "frames-table",
      "sourceNodeId": "select-frames",
      "sourceOutput": "selection",
      "targetNodeId": "frame-table",
      "targetInput": "selection"
    },
    {
      "id": "frames-hex",
      "sourceNodeId": "select-frames",
      "sourceOutput": "selection",
      "targetNodeId": "frame-hex",
      "targetInput": "bytes"
    }
  ]
}
