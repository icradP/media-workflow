{
  "version": 1,
  "name": "Ring Buffer Live Source",
  "description": "Decode PCM → Ring Buffer Source → Filter → Destination. Run to fill the ring; Live Play clocks it out.",
  "nodes": [
    { "id": "file", "type": "file_loader", "position": [60, 180] },
    { "id": "analyze", "type": "auto_analyze", "position": [300, 180] },
    {
      "id": "decode",
      "type": "audio_decode",
      "position": [540, 180],
      "params": {
        "trackIndex": 0,
        "startTimeSeconds": 0,
        "endTimeSeconds": 10
      }
    },
    {
      "id": "ring",
      "type": "ring_buffer_source",
      "position": [800, 160],
      "params": {
        "fillMode": "static_once",
        "ioMode": "consumer_pull",
        "clockMode": "realtime",
        "rate": 1,
        "targetSampleRate": 0,
        "targetFrameRate": 0,
        "capacitySeconds": 10,
        "underrunPolicy": "loop",
        "overrunPolicy": "drop_oldest",
        "loop": true,
        "gain": 1
      }
    },
    {
      "id": "filter",
      "type": "audio_biquadfilter",
      "position": [1060, 160],
      "params": {
        "type": "lowpass",
        "frequency": 12000,
        "Q": 1,
        "detune": 0
      }
    },
    {
      "id": "destination",
      "type": "audio_destination",
      "position": [1320, 80]
    },
    {
      "id": "analyser",
      "type": "audio_analyser",
      "position": [1320, 240],
      "params": {
        "fftSize": "2048",
        "minDecibels": -100,
        "maxDecibels": -10,
        "smoothingTimeConstant": 0.5
      }
    },
    {
      "id": "viz",
      "type": "audio_visualization",
      "position": [1580, 220],
      "params": {
        "continuous": true,
        "mark": -1
      }
    }
  ],
  "edges": [
    {
      "id": "file-analyze",
      "sourceNodeId": "file",
      "sourceOutput": "source",
      "targetNodeId": "analyze",
      "targetInput": "source"
    },
    {
      "id": "analyze-decode",
      "sourceNodeId": "analyze",
      "sourceOutput": "asset",
      "targetNodeId": "decode",
      "targetInput": "source"
    },
    {
      "id": "decode-ring",
      "sourceNodeId": "decode",
      "sourceOutput": "audio",
      "targetNodeId": "ring",
      "targetInput": "pcm"
    },
    {
      "id": "ring-filter",
      "sourceNodeId": "ring",
      "sourceOutput": "out",
      "targetNodeId": "filter",
      "targetInput": "in"
    },
    {
      "id": "filter-dest",
      "sourceNodeId": "filter",
      "sourceOutput": "out",
      "targetNodeId": "destination",
      "targetInput": "in"
    },
    {
      "id": "filter-analyser",
      "sourceNodeId": "filter",
      "sourceOutput": "out",
      "targetNodeId": "analyser",
      "targetInput": "in"
    },
    {
      "id": "analyser-viz",
      "sourceNodeId": "analyser",
      "sourceOutput": "spectrum",
      "targetNodeId": "viz",
      "targetInput": "spectrum"
    }
  ]
}
