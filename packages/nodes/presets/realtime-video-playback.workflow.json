{
  "version": 1,
  "name": "Realtime Video Playback",
  "description": "Select video → EncodedTrack → Ring Buffer stream-decode → Video Preview. Run materializes packets only; Live Play clocks WebCodecs into a short decoded window.",
  "nodes": [
    { "id": "file", "type": "file_loader", "position": [60, 180] },
    { "id": "analyze", "type": "auto_analyze", "position": [300, 180] },
    {
      "id": "decode",
      "type": "video_decode",
      "position": [560, 160],
      "params": {
        "trackIndex": 0,
        "startIndex": 0,
        "endIndex": -1,
        "startTimeSeconds": 0,
        "endTimeSeconds": -1,
        "frameType": "all",
        "limit": -1,
        "eagerDecode": false,
        "outputFormat": "I420"
      }
    },
    {
      "id": "ring",
      "type": "ring_buffer_source",
      "position": [860, 140],
      "params": {
        "fillMode": "static_once",
        "ioMode": "consumer_pull",
        "clockMode": "fixed_rate",
        "rate": 1,
        "targetSampleRate": 0,
        "targetFrameRate": 30,
        "capacitySeconds": 2,
        "underrunPolicy": "loop",
        "overrunPolicy": "drop_oldest",
        "loop": true,
        "gain": 1
      }
    },
    {
      "id": "preview",
      "type": "video_preview",
      "position": [1160, 160],
      "params": {
        "frameIndex": 0,
        "continuous": true
      }
    }
  ],
  "edges": [
    {
      "id": "file-analyze",
      "sourceNodeId": "file",
      "sourceOutput": "source",
      "targetNodeId": "analyze",
      "targetInput": "source"
    },
    {
      "id": "analyze-decode",
      "sourceNodeId": "analyze",
      "sourceOutput": "asset",
      "targetNodeId": "decode",
      "targetInput": "source"
    },
    {
      "id": "decode-ring-track",
      "sourceNodeId": "decode",
      "sourceOutput": "track",
      "targetNodeId": "ring",
      "targetInput": "track"
    },
    {
      "id": "ring-preview",
      "sourceNodeId": "ring",
      "sourceOutput": "stream",
      "targetNodeId": "preview",
      "targetInput": "stream"
    }
  ]
}
