{
  "version": 1,
  "name": "Decode First Keyframe Display",
  "description": "Analyze media, decode the first video keyframe, and preview the YUV frame.",
  "nodes": [
    { "id": "file", "type": "file_loader", "position": [80, 160] },
    { "id": "analyze", "type": "auto_analyze", "position": [360, 160] },
    {
      "id": "select-video",
      "type": "track_selector",
      "position": [640, 80],
      "params": { "kind": "video", "index": 0 }
    },
    {
      "id": "request-frame",
      "type": "video_frame_request",
      "position": [920, 120],
      "params": {
        "startIndex": 0,
        "endIndex": -1,
        "startTimeSeconds": 0,
        "endTimeSeconds": -1,
        "frameType": "key",
        "limit": 1,
        "outputFormat": "I420"
      }
    },
    {
      "id": "decode-video",
      "type": "webcodecs_video_decoder",
      "position": [1200, 120]
    },
    {
      "id": "select-decoded",
      "type": "decoded_frame_selector",
      "position": [1480, 120],
      "params": { "selection": "first" }
    },
    {
      "id": "preview-yuv",
      "type": "yuv_preview",
      "position": [1760, 120]
    }
  ],
  "edges": [
    {
      "id": "file-analyze",
      "sourceNodeId": "file",
      "sourceOutput": "source",
      "targetNodeId": "analyze",
      "targetInput": "source"
    },
    {
      "id": "analyze-select-video",
      "sourceNodeId": "analyze",
      "sourceOutput": "asset",
      "targetNodeId": "select-video",
      "targetInput": "asset"
    },
    {
      "id": "analyze-request-frame",
      "sourceNodeId": "analyze",
      "sourceOutput": "asset",
      "targetNodeId": "request-frame",
      "targetInput": "asset"
    },
    {
      "id": "select-request-frame",
      "sourceNodeId": "select-video",
      "sourceOutput": "track",
      "targetNodeId": "request-frame",
      "targetInput": "track"
    },
    {
      "id": "request-decode",
      "sourceNodeId": "request-frame",
      "sourceOutput": "request",
      "targetNodeId": "decode-video",
      "targetInput": "request"
    },
    {
      "id": "decode-select",
      "sourceNodeId": "decode-video",
      "sourceOutput": "frames",
      "targetNodeId": "select-decoded",
      "targetInput": "frames"
    },
    {
      "id": "select-preview",
      "sourceNodeId": "select-decoded",
      "sourceOutput": "frame",
      "targetNodeId": "preview-yuv",
      "targetInput": "frame"
    }
  ]
}
